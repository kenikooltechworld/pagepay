# backend/.env.example
DATABASE_URL=mysql+aiomysql://pagepay:pagepass@localhost:3306/pagepay
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Admin / cron shared secret. Required by X-Admin-Token on /admin/* routes.
# The cron container and operator scripts must send this exact value.
ADMIN_TOKEN=dev-admin-token

# Content providers
GNEWS_API_KEY=
GUTENDEX_BASE_URL=https://gutendex.com

# Flutterwave (Phase 4)
FLUTTERWAVE_CLIENT_ID=
FLUTTERWAVE_CLIENT_SECRET=
FLUTTERWAVE_SECRET_HASH=
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com

# AI providers (Phase 3 — Student AI Exam Prep)
# Get keys from:
#   Gemini:  https://aistudio.google.com/app/apikey
#   Groq:    https://console.groq.com/keys
#   OpenRouter: https://openrouter.ai/keys
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# AdMob (Phase 2)
ADMOB_APP_ID_ANDROID=
ADMOB_APP_ID_IOS=

# AppLovin (Phase 2)
APPLOVIN_SDK_KEY=
APPLOVIN_INITIALIZATION_SCORE=

# Paystack (Phase 4 — Payments). Get keys from https://dashboard.paystack.com/#/settings/developers.
# NOTE: Paystack signs webhooks using your SECRET KEY (not a separate webhook secret).
# Just configure the webhook URL in Paystack dashboard - no secret needed!
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Public base URL we expose in Paystack's dashboard for return + webhook
# URLs. Defaults to localhost for `paystack-cli listen-forward`; override
# in production to the real public domain (e.g. https://pagepay.onrender.com).
# IMPORTANT: Use HTTPS in production!
PUBLIC_BASE_URL=http://localhost:8000

# Frontend URL for redirects after payment completion (wallet funding, subscriptions).
# Development: Use Expo dev client URL (exp://localhost:8081)
# Production: Use your production app URL or deep link scheme
# Example: https://pagepay.com or pagepay://
FRONTEND_URL=exp://localhost:8081


# Phase 7: Cloudinary for task proof uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=pagepay/tasks
